# ============================================================
# F1 Simulator — environment variables
# Copy to .env and fill in values before running
# ============================================================

# --- Database ---
#DATABASE_URL=postgresql+asyncpg://f1user:f1pass@localhost:5432/f1sim
# Used inside Docker Compose (hostname = service name)
DATABASE_URL=postgresql+asyncpg://f1user:f1pass@postgres:5432/f1sim

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# REDIS_URL=redis://redis:6379/0   # inside Docker

# --- FastF1 cache ---
F1_CACHE_DIR=./data/fastf1_cache

# --- Simulation defaults ---
DEFAULT_N_SIMS=10000
DEFAULT_RANDOMNESS=0.15

# --- API ---
API_SECRET_KEY=changeme-replace-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# CELERY_BROKER_URL=redis://redis:6379/0   # inside Docker
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
